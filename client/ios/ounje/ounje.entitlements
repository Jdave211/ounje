<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>com.apple.developer.applesignin</key>
    <array>
      <string>Default</string>
    </array>
    <key>com.apple.security.application-groups</key>
    <array>
      <string>group.net.ounje.shared</string>
    </array>
    <key>com.apple.developer.associated-domains</key>
    <array>
      <string>applinks:ounje-idbl.onrender.com</string>
    </array>
    <!--
      APNs environment.
        "development" = Xcode-installed Debug builds, ad-hoc dev provisioning →
          server must POST to api.development.push.apple.com.
        "production"  = TestFlight + App Store builds →
          server posts to api.push.apple.com.
      Before shipping a TestFlight or App Store build, flip this to
      "production" (or maintain a Release-specific entitlements file). The iOS
      client tells the server which environment it's in via the `environment`
      field on /v1/push-tokens/register, so the server picks the right gateway.
    -->
    <key>aps-environment</key>
    <string>development</string>
  </dict>
</plist>
