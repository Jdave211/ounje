{
  "name": "ounje",
  "version": "1.0.0",
  "description": "Ounje \u2014 Nigerian food app. Swift iOS client + Node.js API server.",
  "type": "module",
  "scripts": {
    "server": "nodemon server/server.js",
    "start": "node server/server.js",
    "flavorgraph:index": "python3 server/scripts/build_flavorgraph_index.py",
    "recipes:export-corpus": "python3 server/scripts/export_recipe_training_corpus.py",
    "recipes:create-finetune": "node server/scripts/create_recipe_finetune_job.mjs",
    "recipes:status": "node -e \"import('./server/lib/recipe-model-registry.js').then(async (m) => { const r = await m.refreshRecipeFineTuneStatus(); console.log(JSON.stringify(r, null, 2)); process.exit(0); })\""
  },
  "dependencies": {
    "axios": "^1.6.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "mongodb": "^7.1.1",
    "mongoose": "^9.3.2",
    "nanoid": "^5.0.7",
    "openai": "^4.24.1"
  },
  "nodemonConfig": {
    "watch": [
      "server"
    ],
    "delay": "3"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.7",
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "nodemon": "^3.1.4"
  }
}
