{
  "name": "ounje",
  "version": "1.0.0",
  "description": "Ounje — Nigerian food app. Swift iOS client + Node.js API server.",
  "type": "module",
  "scripts": {
    "server": "nodemon --watch server --ext js,mjs,json --exec \"bash server/scripts/start-server.sh\"",
    "start": "bash server/scripts/start-server.sh",
    "start:vm": "node server/scripts/vm-bootstrap.mjs",
    "sync:ios-host": "bash server/scripts/start-server.sh --sync-only",
    "flavorgraph:index": "python3 server/scripts/build_flavorgraph_index.py",
    "recipes:export-corpus": "python3 server/scripts/export_recipe_training_corpus.py",
    "recipes:create-finetune": "node server/scripts/create_recipe_finetune_job.mjs",
    "recipes:status": "node -e \"import('./server/lib/recipe-model-registry.js').then(async (m) => { const r = await m.refreshRecipeFineTuneStatus(); console.log(JSON.stringify(r, null, 2)); process.exit(0); })\"",
    "recipes:classify-discover": "node server/scripts/classify_discover_brackets.mjs",
    "recipes:backfill-measurements": "node server/scripts/backfill_recipe_measurements.mjs",
    "recipes:ingestion-worker": "node server/scripts/recipe_ingestion_worker.mjs",
    "recipes:ingestion-worker:vm": "NODE_ENV=production node server/scripts/recipe_ingestion_worker.mjs --worker-id droplet_recipe_ingest",
    "recipes:ingestion-once": "node server/scripts/recipe_ingestion_worker.mjs --once",
    "instacart:test-cart": "node server/scripts/test-instacart-cart.mjs watermelon",
    "instacart:clear-cart": "node server/scripts/clear-instacart-cart.mjs",
    "instacart:add-current-plan": "node server/scripts/add-current-plan-to-instacart.mjs",
    "instacart:add-current-plan:cloud": "INSTACART_USE_BROWSER_USE=1 node server/scripts/add-current-plan-to-instacart-browseruse.mjs",
    "instacart:cleanup-logs": "node server/scripts/cleanup_instacart_run_logs.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.6.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "mongodb": "^7.1.1",
    "mongoose": "^9.3.2",
    "nanoid": "^5.0.7",
    "openai": "^4.24.1",
    "playwright": "^1.59.1",
    "tesseract.js": "^7.0.0",
    "youtube-dl-exec": "^3.1.4"
  },
  "nodemonConfig": {
    "watch": [
      "server"
    ],
    "delay": "3"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.7",
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "nodemon": "^3.1.4"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jdave211/ounje.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Jdave211/ounje/issues"
  },
  "homepage": "https://github.com/Jdave211/ounje#readme"
}
