# ── Grocery delivery providers ────────────────────────────────────────────────

# Kroger Developer API
# Register at: https://developer.kroger.com
# Create an app → copy Client ID + Client Secret
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# ── Browser Automation (Primary Pipeline) ─────────────────────────────────────

# Browser Use Cloud API  ← AI browser agent for Walmart, Amazon Fresh, Target
# Sign up at: https://cloud.browser-use.com
# Get API key at: https://cloud.browser-use.com/settings?tab=api-keys
BROWSER_USE_API_KEY=

# ── User Verification Infrastructure ──────────────────────────────────────────

# Lumbox  ← Programmatic email inboxes for account verification
# Sign up at: https://lumbox.co
# API key at: https://app.lumbox.co/settings/api-keys
# Used for: receiving verification emails, OTP extraction
LUMBOX_API_KEY=

# AgentSIM  ← Real SIM phone numbers for SMS verification
# Sign up at: https://console.agentsim.dev
# API key at: Console → API Keys → Create key
# Used for: SMS OTP verification (bypasses VoIP detection)
AGENTSIM_API_KEY=

# ── Existing keys ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# Recipe ingestion model split
# Keep expensive extraction narrow; use nano for gates, checks, and completion fills.
RECIPE_INGESTION_MODEL=gpt-4o-mini
RECIPE_GATE_MODEL=gpt-5-nano
RECIPE_IMPORT_COMPLETION_MODEL=gpt-5-nano
RECIPE_SEARCH_SYNTHESIS_MODEL=gpt-5-nano
RECIPE_IMAGE_CHECK_MODEL=gpt-5-nano
RECIPE_ADAPTATION_MODEL=gpt-4o-mini

# OpenAI usage logging and soft spend gates
OUNJE_ENABLE_AI_CALL_LOGGING=1
OUNJE_AI_DAILY_SPEND_LIMIT_USD=8
OUNJE_AI_USER_DAILY_SPEND_LIMIT_USD=3
OUNJE_AI_BUDGET_FAIL_CLOSED=0

SUPABASE_URL=https://ztqptjimmcdoriefkqcx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App Store Server Notifications V2
# Configure App Store Connect to POST signedPayload to:
# https://<api-host>/v1/app-store/notifications
APP_STORE_BUNDLE_ID=net.ounje
APP_STORE_ENVIRONMENT=Production
APP_STORE_APP_APPLE_ID=
APP_STORE_ENABLE_ONLINE_CHECKS=1
# Optional: set when Render should read pinned Apple root certs from disk.
APP_STORE_ROOT_CERTS_DIR=

# Feedback forwarding
OUNJE_FEEDBACK_FORWARD_EMAIL=jagadave21@gmail.com
