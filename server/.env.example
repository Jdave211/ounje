# ── Grocery delivery providers ────────────────────────────────────────────────

# MealMe API  ← PRIMARY provider (US + Canada, 1M+ stores, in-app checkout)
# Apply at: https://www.mealme.ai/api  →  api@mealme.ai for enterprise key
# Header: Id-Token: <key>
MEALME_API_KEY=

# Instacart Developer Platform  ← fallback / hosted shoppable page
# Apply at: https://www.instacart.com/business_hub/developer_platform
# Apply at: https://www.instacart.com/business_hub/developer_platform
# Once approved you'll receive a partner API key.
INSTACART_API_KEY=

# Kroger Developer API
# Register at: https://developer.kroger.com
# Create an app → copy Client ID + Client Secret
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# ── Browser Automation (Primary Pipeline) ─────────────────────────────────────

# Browser Use Cloud API  ← AI browser agent for Walmart, Amazon Fresh, Target
# Sign up at: https://cloud.browser-use.com
# Get API key at: https://cloud.browser-use.com/settings?tab=api-keys
BROWSER_USE_API_KEY=

# ── User Verification Infrastructure ──────────────────────────────────────────

# Lumbox  ← Programmatic email inboxes for account verification
# Sign up at: https://lumbox.co
# API key at: https://app.lumbox.co/settings/api-keys
# Used for: receiving verification emails, OTP extraction
LUMBOX_API_KEY=

# AgentSIM  ← Real SIM phone numbers for SMS verification
# Sign up at: https://console.agentsim.dev
# API key at: Console → API Keys → Create key
# Used for: SMS OTP verification (bypasses VoIP detection)
AGENTSIM_API_KEY=

